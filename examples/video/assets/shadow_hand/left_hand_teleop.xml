<mujoco model="left_shadow_hand_teleop">
  <!-- Shadow Hand E3M5 (left) modified for floating-base teleop.
       Based on left_hand.xml with the following changes:
       - Added lh_base body with 3 slide + 1 ball joint for 6-DOF wrist pose.
       - Removed wrist hinge joints (WRJ1, WRJ2) — wrist is rigid.
       - Removed wrist actuators; added slide position actuators.
       - Reduced forearm mass (floating, no gravity).
       - Added fingertip + palm sites for retargeting.
       - All asset/class names prefixed with lh_ for bimanual compatibility.
  -->
  <compiler angle="radian" meshdir="assets" autolimits="true"/>

  <option cone="elliptic" impratio="10"/>

  <default>
    <default class="left_hand">
      <mesh scale="0.001 0.001 0.001"/>
      <joint axis="1 0 0" damping="0.05" armature="0.0002" frictionloss="0.01"/>
      <position forcerange="-1 1"/>

      <default class="lh_thumb">
        <default class="lh_thbase">
          <joint axis="0 0 1" range="-1.0472 1.0472"/>
          <position kp="0.4" ctrlrange="-1.0472 1.0472" forcerange="-3 3"/>
        </default>
        <default class="lh_thproximal">
          <joint axis="-1 0 0" range="0 1.22173"/>
          <position ctrlrange="0 1.22173" forcerange="-2 2"/>
        </default>
        <default class="lh_thhub">
          <joint axis="-1 0 0" range="-0.20944 0.20944"/>
          <position kp="0.5" ctrlrange="-0.20944 0.20944"/>
        </default>
        <default class="lh_thmiddle">
          <joint axis="0 -1 0" range="-0.698132 0.698132"/>
          <position kp="1.5" ctrlrange="-0.698132 0.698132"/>
        </default>
        <default class="lh_thdistal">
          <joint range="-0.261799 1.5708"/>
          <position ctrlrange="-0.261799 1.5708"/>
        </default>
      </default>

      <default class="lh_metacarpal">
        <joint axis="0.573576 0 0.819152" range="0 0.785398"/>
        <position ctrlrange="0 0.785398"/>
      </default>
      <default class="lh_knuckle">
        <joint axis="0 -1 0" range="-0.349066 0.349066"/>
        <position ctrlrange="-0.349066 0.349066"/>
      </default>
      <default class="lh_proximal">
        <joint range="-0.261799 1.5708"/>
        <position ctrlrange="-0.261799 1.5708"/>
      </default>
      <default class="lh_middle_distal">
        <joint range="0 1.5708"/>
        <position kp="0.5" ctrlrange="0 3.1415"/>
      </default>

      <default class="lh_plastic">
        <geom solimp="0.5 0.99 0.0001" solref="0.005 1"/>
        <default class="lh_plastic_visual">
          <geom type="mesh" material="lh_black" contype="0" conaffinity="0" group="2"/>
        </default>
        <default class="lh_plastic_collision">
          <geom group="3"/>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <material name="lh_black" specular="0.5" shininess="0.25" rgba="0.16355 0.16355 0.16355 1"/>
    <material name="lh_gray" specular="0.0" shininess="0.25" rgba="0.80848 0.80848 0.80848 1"/>
    <material name="lh_metallic" specular="0" shininess="0.25" rgba="0.9 0.9 0.9 1"/>

    <mesh name="lh_forearm_0" class="left_hand" file="forearm_0.obj"/>
    <mesh name="lh_forearm_1" class="left_hand" file="forearm_1.obj"/>
    <mesh name="lh_forearm_collision" class="left_hand" file="forearm_collision.obj"/>
    <mesh name="lh_wrist" class="left_hand" file="wrist.obj" scale="-0.001 0.001 0.001"/>
    <mesh name="lh_palm" class="left_hand" file="palm.obj" scale="-0.001 0.001 0.001"/>
    <mesh name="lh_f_knuckle" class="left_hand" file="f_knuckle.obj"/>
    <mesh name="lh_f_proximal" class="left_hand" file="f_proximal.obj"/>
    <mesh name="lh_f_middle" class="left_hand" file="f_middle.obj"/>
    <mesh name="lh_f_distal_pst" class="left_hand" file="f_distal_pst.obj"/>
    <mesh name="lh_lf_metacarpal" class="left_hand" file="lf_metacarpal.obj" scale="-0.001 0.001 0.001"/>
    <mesh name="lh_th_proximal" class="left_hand" file="th_proximal.obj"/>
    <mesh name="lh_th_middle" class="left_hand" file="th_middle.obj"/>
    <mesh name="lh_th_distal_pst" class="left_hand" file="th_distal_pst.obj"/>
  </asset>

  <worldbody>
    <!-- Floating base: slide joints for position, ball joint for rotation. -->
    <body name="lh_base">
      <joint name="lh_pos_x" type="slide" axis="1 0 0" range="-1 1" damping="0" armature="1"/>
      <joint name="lh_pos_y" type="slide" axis="0 1 0" range="-1 1" damping="0" armature="1"/>
      <joint name="lh_pos_z" type="slide" axis="0 0 1" range="-1 1" damping="0" armature="1"/>
      <joint name="lh_rot" type="ball" damping="0" armature="1"/>
      <!-- Original forearm body, now a child of the floating base. -->
      <body name="lh_forearm" childclass="left_hand" quat="0 1 0 1">
        <inertial mass="0.1" pos="0 0 0.09" diaginertia="0.001 0.001 0.001"/>
        <geom class="lh_plastic_visual" mesh="lh_forearm_0" material="lh_gray"/>
        <geom class="lh_plastic_visual" mesh="lh_forearm_1"/>
        <geom class="lh_plastic_collision" type="mesh" mesh="lh_forearm_collision"/>
        <geom class="lh_plastic_collision" size="0.035 0.035 0.035" pos="0.01 0.0 0.181"
          quat="0.380188 0.924909 0 0" type="box"/>
        <!-- Wrist body — WRJ2 joint REMOVED (frozen). -->
        <body name="lh_wrist" pos="0.01 0 0.21301" quat="1 0 0 1">
          <inertial mass="0.1" pos="0 0 0.029" quat="0.5 0.5 0.5 0.5"
            diaginertia="6.4e-05 4.38e-05 3.5e-05"/>
          <geom class="lh_plastic_visual" mesh="lh_wrist" material="lh_metallic"/>
          <geom size="0.0135 0.015" quat="0.499998 0.5 0.5 -0.500002" type="cylinder"
            class="lh_plastic_collision"/>
          <geom size="0.011 0.005" pos="0.026 0 0.034" quat="1 0 1 0" type="cylinder"
            class="lh_plastic_collision"/>
          <geom size="0.011 0.005" pos="-0.031 0 0.034" quat="1 0 1 0" type="cylinder"
            class="lh_plastic_collision"/>
          <geom size="0.0135 0.009 0.005" pos="0.021 0 0.011" quat="-0.923879 0 0.382684 0"
            type="box" class="lh_plastic_collision"/>
          <geom size="0.0135 0.009 0.005" pos="-0.026 0 0.01" quat="-0.923879 0 -0.382684 0"
            type="box" class="lh_plastic_collision"/>
          <!-- Palm body — WRJ1 joint REMOVED (frozen). -->
          <body name="lh_palm" pos="0 0 0.034">
            <inertial mass="0.3" pos="0 0 0.035" quat="1 0 0 1"
              diaginertia="0.0005287 0.0003581 0.000191"/>
            <site name="lh_palm_site" pos="0 0 0.035" group="4"/>
            <geom class="lh_plastic_visual" mesh="lh_palm"/>
            <geom size="0.031 0.0035 0.049" pos="-0.011 0.0085 0.038" type="box"
              class="lh_plastic_collision"/>
            <geom size="0.018 0.0085 0.049" pos="0.002 -0.0035 0.038" type="box"
              class="lh_plastic_collision"/>
            <geom size="0.013 0.0085 0.005" pos="-0.029 -0.0035 0.082" type="box"
              class="lh_plastic_collision"/>
            <geom size="0.013 0.007 0.009" pos="-0.0265 -0.001 0.07"
              quat="0.987241 0.0990545 0.0124467 -0.124052" type="box" class="lh_plastic_collision"/>
            <geom size="0.0105 0.0135 0.0112" pos="-0.0315 -0.0085 0.001" type="box"
              class="lh_plastic_collision"/>
            <geom size="0.011 0.0025 0.015" pos="-0.0125 -0.015 0.004"
              quat="-0.971338 0 0 -0.237703" type="box" class="lh_plastic_collision"/>
            <geom size="0.009 0.012 0.002" pos="-0.011 0 0.089" type="box"
              class="lh_plastic_collision"/>
            <geom size="0.01 0.012 0.02" pos="0.03 0 0.009" type="box"
              class="lh_plastic_collision"/>
            <!-- First (index) finger — X-mirrored positions -->
            <body name="lh_ffknuckle" pos="-0.033 0 0.095">
              <inertial mass="0.008" pos="0 0 0" quat="0.5 0.5 -0.5 0.5"
                diaginertia="3.2e-07 2.6e-07 2.6e-07"/>
              <joint name="lh_FFJ4" class="lh_knuckle" axis="0 1 0"/>
              <geom pos="0 0 0.0005" class="lh_plastic_visual" mesh="lh_f_knuckle" material="lh_metallic"/>
              <geom size="0.009 0.009" quat="1 0 1 0" type="cylinder" class="lh_plastic_collision"/>
              <body name="lh_ffproximal">
                <inertial mass="0.03" pos="0 0 0.0225" quat="1 0 0 1"
                  diaginertia="1e-05 9.8e-06 1.8e-06"/>
                <joint name="lh_FFJ3" class="lh_proximal"/>
                <geom class="lh_plastic_visual" mesh="lh_f_proximal"/>
                <geom size="0.009 0.02" pos="0 0 0.025" type="capsule" class="lh_plastic_collision"/>
                <body name="lh_ffmiddle" pos="0 0 0.045">
                  <inertial mass="0.017" pos="0 0 0.0125" quat="1 0 0 1"
                    diaginertia="2.7e-06 2.6e-06 8.7e-07"/>
                  <joint name="lh_FFJ2" class="lh_middle_distal"/>
                  <geom class="lh_plastic_visual" mesh="lh_f_middle"/>
                  <geom size="0.009 0.0125" pos="0 0 0.0125" type="capsule"
                    class="lh_plastic_collision"/>
                  <body name="lh_ffdistal" pos="0 0 0.025">
                    <inertial mass="0.013" pos="0 0 0.0130769" quat="1 0 0 1"
                      diaginertia="1.28092e-06 1.12092e-06 5.3e-07"/>
                    <joint name="lh_FFJ1" class="lh_middle_distal"/>
                    <geom class="lh_plastic_visual" mesh="lh_f_distal_pst"/>
                    <geom class="lh_plastic_collision" type="mesh" mesh="lh_f_distal_pst"/>
                    <site name="lh_ff_tip" pos="0 0 0.026" group="4"/>
                  </body>
                </body>
              </body>
            </body>
            <!-- Middle finger -->
            <body name="lh_mfknuckle" pos="-0.011 0 0.099">
              <inertial mass="0.008" pos="0 0 0" quat="0.5 0.5 -0.5 0.5"
                diaginertia="3.2e-07 2.6e-07 2.6e-07"/>
              <joint name="lh_MFJ4" class="lh_knuckle" axis="0 1 0"/>
              <geom pos="0 0 0.0005" class="lh_plastic_visual" mesh="lh_f_knuckle" material="lh_metallic"/>
              <geom size="0.009 0.009" quat="1 0 1 0" type="cylinder" class="lh_plastic_collision"/>
              <body name="lh_mfproximal">
                <inertial mass="0.03" pos="0 0 0.0225" quat="1 0 0 1"
                  diaginertia="1e-05 9.8e-06 1.8e-06"/>
                <joint name="lh_MFJ3" class="lh_proximal"/>
                <geom class="lh_plastic_visual" mesh="lh_f_proximal"/>
                <geom size="0.009 0.02" pos="0 0 0.025" type="capsule" class="lh_plastic_collision"/>
                <body name="lh_mfmiddle" pos="0 0 0.045">
                  <inertial mass="0.017" pos="0 0 0.0125" quat="1 0 0 1"
                    diaginertia="2.7e-06 2.6e-06 8.7e-07"/>
                  <joint name="lh_MFJ2" class="lh_middle_distal"/>
                  <geom class="lh_plastic_visual" mesh="lh_f_middle"/>
                  <geom size="0.009 0.0125" pos="0 0 0.0125" type="capsule"
                    class="lh_plastic_collision"/>
                  <body name="lh_mfdistal" pos="0 0 0.025">
                    <inertial mass="0.013" pos="0 0 0.0130769" quat="1 0 0 1"
                      diaginertia="1.28092e-06 1.12092e-06 5.3e-07"/>
                    <joint name="lh_MFJ1" class="lh_middle_distal"/>
                    <geom class="lh_plastic_visual" mesh="lh_f_distal_pst"/>
                    <geom class="lh_plastic_collision" type="mesh" mesh="lh_f_distal_pst"/>
                    <site name="lh_mf_tip" pos="0 0 0.026" group="4"/>
                  </body>
                </body>
              </body>
            </body>
            <!-- Ring finger -->
            <body name="lh_rfknuckle" pos="0.011 0 0.095">
              <inertial mass="0.008" pos="0 0 0" quat="0.5 0.5 -0.5 0.5"
                diaginertia="3.2e-07 2.6e-07 2.6e-07"/>
              <joint name="lh_RFJ4" class="lh_knuckle"/>
              <geom pos="0 0 0.0005" class="lh_plastic_visual" mesh="lh_f_knuckle" material="lh_metallic"/>
              <geom size="0.009 0.009" quat="1 0 1 0" type="cylinder" class="lh_plastic_collision"/>
              <body name="lh_rfproximal">
                <inertial mass="0.03" pos="0 0 0.0225" quat="1 0 0 1"
                  diaginertia="1e-05 9.8e-06 1.8e-06"/>
                <joint name="lh_RFJ3" class="lh_proximal"/>
                <geom class="lh_plastic_visual" mesh="lh_f_proximal"/>
                <geom size="0.009 0.02" pos="0 0 0.025" type="capsule" class="lh_plastic_collision"/>
                <body name="lh_rfmiddle" pos="0 0 0.045">
                  <inertial mass="0.017" pos="0 0 0.0125" quat="1 0 0 1"
                    diaginertia="2.7e-06 2.6e-06 8.7e-07"/>
                  <joint name="lh_RFJ2" class="lh_middle_distal"/>
                  <geom class="lh_plastic_visual" mesh="lh_f_middle"/>
                  <geom size="0.009 0.0125" pos="0 0 0.0125" type="capsule"
                    class="lh_plastic_collision"/>
                  <body name="lh_rfdistal" pos="0 0 0.025">
                    <inertial mass="0.013" pos="0 0 0.0130769" quat="1 0 0 1"
                      diaginertia="1.28092e-06 1.12092e-06 5.3e-07"/>
                    <joint name="lh_RFJ1" class="lh_middle_distal"/>
                    <geom class="lh_plastic_visual" mesh="lh_f_distal_pst"/>
                    <geom class="lh_plastic_collision" type="mesh" mesh="lh_f_distal_pst"/>
                    <site name="lh_rf_tip" pos="0 0 0.026" group="4"/>
                  </body>
                </body>
              </body>
            </body>
            <!-- Little finger -->
            <body name="lh_lfmetacarpal" pos="0.033 0 0.02071">
              <inertial mass="0.03" pos="0 0 0.04" quat="1 0 0 1"
                diaginertia="1.638e-05 1.45e-05 4.272e-06"/>
              <joint name="lh_LFJ5" class="lh_metacarpal" axis="0.573576 0 -0.819152"/>
              <geom class="lh_plastic_visual" mesh="lh_lf_metacarpal"/>
              <geom size="0.011 0.012 0.025" pos="-0.002 0 0.033" type="box"
                class="lh_plastic_collision"/>
              <body name="lh_lfknuckle" pos="0 0 0.06579">
                <inertial mass="0.008" pos="0 0 0" quat="0.5 0.5 -0.5 0.5"
                  diaginertia="3.2e-07 2.6e-07 2.6e-07"/>
                <joint name="lh_LFJ4" class="lh_knuckle"/>
                <geom pos="0 0 0.0005" class="lh_plastic_visual" mesh="lh_f_knuckle"
                  material="lh_metallic"/>
                <geom size="0.009 0.009" quat="1 0 1 0" type="cylinder" class="lh_plastic_collision"/>
                <body name="lh_lfproximal">
                  <inertial mass="0.03" pos="0 0 0.0225" quat="1 0 0 1"
                    diaginertia="1e-05 9.8e-06 1.8e-06"/>
                  <joint name="lh_LFJ3" class="lh_proximal"/>
                  <geom class="lh_plastic_visual" mesh="lh_f_proximal"/>
                  <geom size="0.009 0.02" pos="0 0 0.025" type="capsule"
                    class="lh_plastic_collision"/>
                  <body name="lh_lfmiddle" pos="0 0 0.045">
                    <inertial mass="0.017" pos="0 0 0.0125" quat="1 0 0 1"
                      diaginertia="2.7e-06 2.6e-06 8.7e-07"/>
                    <joint name="lh_LFJ2" class="lh_middle_distal"/>
                    <geom class="lh_plastic_visual" mesh="lh_f_middle"/>
                    <geom size="0.009 0.0125" pos="0 0 0.0125" type="capsule"
                      class="lh_plastic_collision"/>
                    <body name="lh_lfdistal" pos="0 0 0.025">
                      <inertial mass="0.013" pos="0 0 0.0130769" quat="1 0 0 1"
                        diaginertia="1.28092e-06 1.12092e-06 5.3e-07"/>
                      <joint name="lh_LFJ1" class="lh_middle_distal"/>
                      <geom class="lh_plastic_visual" mesh="lh_f_distal_pst"/>
                      <geom class="lh_plastic_collision" type="mesh" mesh="lh_f_distal_pst"/>
                      <site name="lh_lf_tip" pos="0 0 0.026" group="4"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
            <!-- Thumb — mirrored position and orientation -->
            <body name="lh_thbase" pos="-0.034 -0.00858 0.029" quat="0 -0.382683 0 0.92388">
              <inertial mass="0.01" pos="0 0 0" diaginertia="1.6e-07 1.6e-07 1.6e-07"/>
              <joint name="lh_THJ5" class="lh_thbase"/>
              <geom class="lh_plastic_collision" size="0.013"/>
              <body name="lh_thproximal">
                <inertial mass="0.04" pos="0 0 0.019" diaginertia="1.36e-05 1.36e-05 3.13e-06"/>
                <joint name="lh_THJ4" class="lh_thproximal"/>
                <geom class="lh_plastic_visual" mesh="lh_th_proximal"/>
                <geom class="lh_plastic_collision" size="0.0105 0.009" pos="0 0 0.02" type="capsule"/>
                <body name="lh_thhub" pos="0 0 0.038">
                  <inertial mass="0.005" pos="0 0 0" diaginertia="1e-06 1e-06 3e-07"/>
                  <joint name="lh_THJ3" class="lh_thhub"/>
                  <geom size="0.011" class="lh_plastic_collision"/>
                  <body name="lh_thmiddle">
                    <inertial mass="0.02" pos="0 0 0.016" diaginertia="5.1e-06 5.1e-06 1.21e-06"/>
                    <joint name="lh_THJ2" class="lh_thmiddle"/>
                    <geom class="lh_plastic_visual" mesh="lh_th_middle"/>
                    <geom size="0.009 0.009" pos="0 0 0.012" type="capsule"
                      class="lh_plastic_collision"/>
                    <geom size="0.01" pos="0 0 0.03" class="lh_plastic_collision"/>
                    <body name="lh_thdistal" pos="0 0 0.032" quat="1 0 0 -1">
                      <inertial mass="0.017" pos="0 0 0.0145588" quat="1 0 0 1"
                        diaginertia="2.37794e-06 2.27794e-06 1e-06"/>
                      <joint name="lh_THJ1" class="lh_thdistal"/>
                      <geom class="lh_plastic_visual" mesh="lh_th_distal_pst"/>
                      <geom class="lh_plastic_collision" type="mesh" mesh="lh_th_distal_pst"/>
                      <site name="lh_th_tip" pos="0 0 0.025" group="4"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="lh_wrist" body2="lh_forearm"/>
    <exclude body1="lh_thproximal" body2="lh_thmiddle"/>
  </contact>

  <tendon>
    <fixed name="lh_FFJ0">
      <joint joint="lh_FFJ2" coef="1"/>
      <joint joint="lh_FFJ1" coef="1"/>
    </fixed>
    <fixed name="lh_MFJ0">
      <joint joint="lh_MFJ2" coef="1"/>
      <joint joint="lh_MFJ1" coef="1"/>
    </fixed>
    <fixed name="lh_RFJ0">
      <joint joint="lh_RFJ2" coef="1"/>
      <joint joint="lh_RFJ1" coef="1"/>
    </fixed>
    <fixed name="lh_LFJ0">
      <joint joint="lh_LFJ2" coef="1"/>
      <joint joint="lh_LFJ1" coef="1"/>
    </fixed>
  </tendon>

  <actuator>
    <!-- Floating base position actuators -->
    <position name="lh_pos_x_position" joint="lh_pos_x" kp="1000" dampratio="1"/>
    <position name="lh_pos_y_position" joint="lh_pos_y" kp="1000" dampratio="1"/>
    <position name="lh_pos_z_position" joint="lh_pos_z" kp="1000" dampratio="1"/>
    <!-- Finger actuators (no wrist actuators — wrist is frozen) -->
    <position name="lh_A_THJ5" joint="lh_THJ5" class="lh_thbase"/>
    <position name="lh_A_THJ4" joint="lh_THJ4" class="lh_thproximal"/>
    <position name="lh_A_THJ3" joint="lh_THJ3" class="lh_thhub"/>
    <position name="lh_A_THJ2" joint="lh_THJ2" class="lh_thmiddle"/>
    <position name="lh_A_THJ1" joint="lh_THJ1" class="lh_thdistal"/>
    <position name="lh_A_FFJ4" joint="lh_FFJ4" class="lh_knuckle"/>
    <position name="lh_A_FFJ3" joint="lh_FFJ3" class="lh_proximal"/>
    <position name="lh_A_FFJ0" tendon="lh_FFJ0" class="lh_middle_distal"/>
    <position name="lh_A_MFJ4" joint="lh_MFJ4" class="lh_knuckle"/>
    <position name="lh_A_MFJ3" joint="lh_MFJ3" class="lh_proximal"/>
    <position name="lh_A_MFJ0" tendon="lh_MFJ0" class="lh_middle_distal"/>
    <position name="lh_A_RFJ4" joint="lh_RFJ4" class="lh_knuckle"/>
    <position name="lh_A_RFJ3" joint="lh_RFJ3" class="lh_proximal"/>
    <position name="lh_A_RFJ0" tendon="lh_RFJ0" class="lh_middle_distal"/>
    <position name="lh_A_LFJ5" joint="lh_LFJ5" class="lh_metacarpal"/>
    <position name="lh_A_LFJ4" joint="lh_LFJ4" class="lh_knuckle"/>
    <position name="lh_A_LFJ3" joint="lh_LFJ3" class="lh_proximal"/>
    <position name="lh_A_LFJ0" tendon="lh_LFJ0" class="lh_middle_distal"/>
  </actuator>
</mujoco>
